# Copy to .env.local and fill values. Never commit .env.local.

# AWS profile (non-PCI) for ECR access (mu bootstrap)
AWS_PROFILE=claude-p1

# Optional local helpers may use these (the Moon Units agent uses MOONUNIT_* from ~/.config/mu/mu.env)
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

ALATION_URL=https://godaddy.alationcloud.com/
ALATION_REFRESH_TOKEN=
# Numeric Alation user ID (required for API token creation)
ALATION_USER_ID=

# Passed into the Moon Units container via run.sh (must use numeric user_id)
MOONUNIT_ALATION='{"refresh_token":"<token>","user_id":12345,"url":"https://godaddy.alationcloud.com"}'

GITHUB_PAT=
GOCODE_API_TOKEN=

