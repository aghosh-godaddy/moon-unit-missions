# Column Comments Enrichment Mission — Environment Variables
# Copy this file to .env and fill in your credentials.
# Do NOT commit .env to version control.

# AWS profile (must be non-PCI for ECR access)
AWS_PROFILE=claude-p1

# Atlassian / Confluence
ATLASSIAN_EMAIL=your-email@godaddy.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token

# Alation (https://godaddy.alationcloud.com)
ALATION_URL=https://godaddy.alationcloud.com/
ALATION_REFRESH_TOKEN=your-alation-refresh-token
ALATION_USER_ID=your-numeric-user-id

# GoCode (https://caas.open-webui.godaddy.com)
GOCODE_API_TOKEN=sk-your-gocode-token

# GitHub PAT (needs repo + read:org scopes)
GITHUB_PAT=ghp_your-github-pat
