# Secrets
.env
.env.local
api-keys.txt

# Mission runtime files
.mu-run.log
.watcher.log
.manifest.generated.yaml

# Per-run shell-redirect logs from chained launches; same content as the
# in-flight mu log, not part of the committed audit trail.
missions/column-comments/output/**/run.log

# Per-run scratch space (cloned repos, intermediate files; outputs are
# copied out to output/<db>/<table>/ on completion)
missions/column-comments/output/**/.workspace/
missions/table-metadata/output/**/.workspace/

# Per-run shell-redirect logs from chained launches
missions/table-metadata/output/**/run.log

# macOS
.DS_Store

# Per-user Claude Code state (project skills under .claude/skills/ are tracked)
.claude/settings.local.json
